# 环境配置模板 — 复制为对应环境的本地文件（均勿提交 Git）
#
#   cp .env.example .env.development   # 本地开发
#   cp .env.example .env.staging       # 预发 / 联调
#   cp .env.example .env.production    # 生产
#
# 启动：ONEMINI_ENV=staging onemini
# 加载顺序：项目目录 .env.{env} → .env.{env}.local，再用户目录 ~/.config/onemini/ 下同文件
# CLI 参数与环境变量仍覆盖 config.toml

# 环境标识：development | staging | production
ONEMINI_ENV=development

# LLM（OpenAI 兼容；与 oneMini-api 的 OPENAI_* / CHAT_MODEL 对应）
ONEMINI_API_KEY=
ONEMINI_BASE_URL=https://api.deepseek.com
ONEMINI_MODEL=deepseek-chat

# API 对应关系（仅文档，CLI 不读取以下变量名）：
#   ONEMINI_API_KEY   ↔ OPENAI_API_KEY
#   ONEMINI_BASE_URL  ↔ OPENAI_BASE_URL
#   ONEMINI_MODEL     ↔ CHAT_MODEL
